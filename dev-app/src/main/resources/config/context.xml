<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:jdbc="http://www.springframework.org/schema/jdbc"
       xmlns="http://www.springframework.org/schema/beans"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd
       http://www.springframework.org/schema/jdbc
       http://www.springframework.org/schema/jdbc/spring-jdbc.xsd"
>


    <bean id="dataSource" class="com.zaxxer.hikari.HikariDataSource" destroy-method="close">
        <property name="driverClassName" value="org.postgresql.Driver"/>
        <property name="jdbcUrl" value="jdbc:postgresql://localhost:5432/parallel"/>
        <property name="username" value="guest"/>
        <property name="password" value="guest"/>

        <!-- Pool sizing. -->
        <property name="connectionTimeout" value="30000"/>
        <property name="maximumPoolSize" value="10"/>
        <property name="minimumIdle" value="2"/>
        <!--
            -1 = never fail app startup because the DB is momentarily slow.
            Hikari skips the initial-connection probe and lazy-connects on
            first request. Without this, a transient SSL-handshake timeout
            (the remote PG taking >30s to respond to enableSSL during a
            cold start) crashes the boot - and the cure is just to restart.
            App startup must be tolerant; failed queries will surface their
            own errors when they actually run.
        -->
        <property name="initializationFailTimeout" value="-1"/>
        <!--
            Lifetimes tuned for remote-PostgreSQL where a NAT/firewall on the
            path closes idle TCP earlier than HikariCP can keep it alive on
            its own. maxLifetime=120000 (2 min) recycles every connection
            well before typical NAT-side timeouts, so the "Failed to
            validate connection ... Possibly consider using a shorter
            maxLifetime" warning stays quiet. keepaliveTime=30000 (HikariCP
            minimum) is the safety net for whatever idle window remains
            inside that 2 minutes.

            connectionTestQuery is intentionally omitted - the PostgreSQL
            JDBC driver is JDBC4-compliant, so HikariCP uses
            Connection.isValid() which is cheaper than running an explicit
            SELECT 1. The HikariCP wiki recommends NOT setting
            connectionTestQuery in that case.

            tcpKeepAlive=true below is mostly a no-op on Windows - the OS
            default keepalive interval is 2 hours, which requires a
            registry edit + reboot to lower. We rely on HikariCP's
            app-level keepalive + aggressive maxLifetime instead.
        -->
        <property name="idleTimeout" value="60000"/>
        <property name="maxLifetime" value="120000"/>
        <property name="keepaliveTime" value="30000"/>

        <!-- Оптимизация для PostgreSQL -->
        <property name="dataSourceProperties">
            <props>
                <!--
                    JDBC-driver-side TCP-connect timeout (seconds). Without it
                    the driver defaults to the OS connect timeout (minutes on
                    Windows), so a routing hiccup can hang the whole boot.
                -->
                <prop key="connectTimeout">10</prop>
                <!--
                    Login-phase timeout (seconds) - covers the SSL handshake
                    and auth roundtrip. The cold-start SocketTimeoutException
                    we hit was inside enableSSL: the remote PG was slow to
                    answer the SSL request. Bumping this from the default 0
                    (which makes login fall back to socketTimeout=30) lets a
                    sluggish handshake complete without dying.
                -->
                <prop key="loginTimeout">30</prop>
                <prop key="socketTimeout">30</prop>
                <prop key="tcpKeepAlive">true</prop>
                <prop key="preparedStatementCacheQueries">256</prop>
                <prop key="preparedStatementCacheSizeMiB">5</prop>
            </props>
        </property>
    </bean>

    <jdbc:initialize-database ignore-failures="ALL">
        <jdbc:script location="classpath*:ddl/*.sql"/>
    </jdbc:initialize-database>

    <!-- prl.nodeRestClient is defined in HttpAdapterConfig.kt (timeouts: connect=5s, read=60s). -->

    <bean class="org.springframework.dao.annotation.PersistenceExceptionTranslationPostProcessor"/>

    <bean id="entityManagerFactory" class="org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean">
        <property name="dataSource" ref="dataSource"/>
        <property name="persistenceUnitName" value="parallelSystemUnit"/>
        <property name="packagesToScan">
            <list>
                <value>com.nelos.parallel</value>
            </list>
        </property>
        <property name="jpaVendorAdapter">
            <bean class="org.springframework.orm.jpa.vendor.HibernateJpaVendorAdapter"/>
        </property>
        <property name="jpaProperties">
            <props>
                <prop key="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</prop>
                <prop key="hibernate.temp.use_jdbc_metadata_defaults">false</prop>
            </props>
        </property>
    </bean>


    <bean id="transactionManager" class="org.springframework.orm.jpa.JpaTransactionManager">
        <property name="entityManagerFactory" ref="entityManagerFactory"/>
    </bean>
</beans>